{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    // Deliberately self-contained (no `extends`) so the package carries its
    // own strictness everywhere it lives. tsup owns emit (ESM + CJS + d.ts);
    // tsc is typecheck-only here.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleDetection": "force",
    "isolatedModules": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "lib": ["ES2022"],
    "target": "ES2022",
    "types": ["node"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts", "tsup.config.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
